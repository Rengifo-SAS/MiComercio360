# App
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (requeridas)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# Cron (opcional)
CRON_SECRET=

# SMTP (opcional, requerido para envío de correos)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Branding / utilidades (opcionales)
COMPANY_NAME=MiComercio360
DEFAULT_COMPANY_ID=

# Deployment helpers (opcionales)
RAILWAY_ENVIRONMENT=false
VERCEL_URL=